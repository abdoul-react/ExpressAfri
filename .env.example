# ExpressAfri — Configuration mobile (Expo)
# Copier ce fichier vers .env et ajuster les valeurs

# URL de l'API backend
EXPO_PUBLIC_API_URL=https://api.expressafri.com

# Désactiver les mocks (false = utilise le vrai backend)
EXPO_PUBLIC_USE_MOCK=false

# URL monitoring (optionnel — erreurs & logs)
EXPO_PUBLIC_MONITORING_URL=https://monitoring.expressafri.com/api/logs
