# ExpressAfri — Configuration API
# Copier ce fichier vers .env et ajuster les valeurs

# === Base de données PostgreSQL ===
DATABASE_URL=postgres://user:password@localhost:5432/expressafri

# === Redis (file d'attente, cache, sessions) ===
REDIS_URL=redis://localhost:6379

# === JWT (authentification) ===
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=7d

# === Serveur ===
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# === PSP (paiement) — à configurer selon le prestataire ===
# Orange Money API
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_API_SECRET=
ORANGE_MONEY_MERCHANT_ID=
ORANGE_MONEY_WEBHOOK_SECRET=

# Wave
WAVE_API_KEY=
WAVE_API_SECRET=
WAVE_WEBHOOK_SECRET=

# Mobile Money (MTN/Orange générique)
MOBILE_MONEY_API_KEY=
MOBILE_MONEY_API_SECRET=
MOBILE_MONEY_WEBHOOK_SECRET=

# Carte bancaire (via PSP PCI-compliant)
CARD_PSP_API_KEY=
CARD_PSP_API_SECRET=
CARD_PSP_WEBHOOK_SECRET=
CARD_PSP_PUBLIC_KEY=

# === Stockage objet (receipts, uploads) ===
OBJECT_STORAGE_ENDPOINT=https://s3.amazonaws.com
OBJECT_STORAGE_REGION=eu-west-1
OBJECT_STORAGE_BUCKET=expressafri-production
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_USE_SSL=true

# === Expo Push Notifications ===
EXPO_ACCESS_TOKEN=

# === Email (réinitialisation de mot de passe) ===
# Laisser vide pour désactiver l'envoi (le lien sera loggé côté serveur en dev)
ADMIN_URL=http://localhost:5173
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=ExpressAfri <noreply@expressafri.com>

# === Secrets (signature webhooks, chiffrement) ===
WEBHOOK_SIGNING_SECRET=
ENCRYPTION_KEY=
